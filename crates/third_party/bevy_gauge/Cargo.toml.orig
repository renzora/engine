[package]
name = "bevy_gauge"
version = "0.4.2"
edition = "2024"
description = "A flexible attribute and stat system for Bevy"
license = "MIT OR Apache-2.0"
repository = "https://github.com/DEMIURGE-studio/bevy_gauge"

[dependencies]
bevy = { version = "0.18.0", features = ["dev"] }
lasso = { version = "0.7", features = ["multi-threaded"] }
inventory = "0.3"
bevy_gauge_macros = { path = "macros", version = "0.4.2" }

[dev-dependencies]
criterion = "0.5"

[[bench]]
name = "stats_bench"
harness = false
