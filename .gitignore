# Rust
/target/
/target-runtime/
updater/target/
**/target/
# Ignore sub-crate lockfiles (only the workspace root Cargo.lock is tracked).
crates/**/Cargo.lock
updater/Cargo.lock

# Build artifacts
rustc-ice-*.txt

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude
.claude/

# WASM build output
templates/web/*.wasm
templates/web/*.wasm.br
templates/web/*.d.ts
templates/web/renzora.js
templates/web/node_modules/

# Build output
/dist/

# SDKs (large binaries, not committed)
docker/sdk/
sdk/

# Docker test files
Dockerfile.test

# Exported builds
/export/

# Editor cache
.renzora/thumbnails/
# Per-project caches (thumbnails, asset import state, etc.) generated
# by the editor inside any project directory the user opens. The legacy
# `.thumbs/` location is kept here too so old projects don't pollute
# diffs while migration runs.
.cache/
.thumbs/
