{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Renzora Engine",
  "version": "1.0.0",
  "identifier": "com.renzora.engine",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Renzora Engine",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/app.png"]
  },
  "plugins": {}
}