# Database Configuration
MONGO_HOST=renzora_mongodb
MONGO_PORT=27017
MONGO_DATABASE=renzora
MONGO_USERNAME=admin
MONGO_PASSWORD=this_is_a_test_password

# Server Configuration
NGINX_PORT=80
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# Security
JWT_SECRET=key
JWT_EXPIRATION=24h
COOKIE_SECRET=another_very_long_and_secure_random_string
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SSL/TLS
SSL_KEY=key.pem
SSL_CERT=cert.pem

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Redis
REDIS_HOST=renzora_redis
REDIS_PORT=6379
REDIS_PASSWORD=someStrongPassword