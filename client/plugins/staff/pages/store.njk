                            <div>
                                <label class="block text-white mb-2">Category</label>
                                <select id="itemCategory" class="w-full bg-[#1a1a1a] border border-[#333] text-white p-2 rounded"></select>
                            </div>
                            <div>
                                <label class="block text-white mb-2">Price</label>
                                <input type="number" id="itemPrice" class="w-full bg-[#1a1a1a] border border-[#333] text-white p-2 rounded">
                            </div>
                            <div>
                                <label class="block text-white mb-2">Rarity</label>
                                <select id="itemRarity" class="w-full bg-[#1a1a1a] border border-[#333] text-white p-2 rounded">
                                    <option value="Common">Common</option>
                                    <option value="Uncommon">Uncommon</option>
                                    <option value="Rare">Rare</option>
                                    <option value="Epic">Epic</option>
                                    <option value="Legendary">Legendary</option>
                                </select>
                            </div>
                            <div class="flex items-center">
                                <input type="checkbox" id="itemActive" class="mr-2">
                                <label class="text-white">Active</label>
                            </div>
                        </div>
                        <div>
                            <label class="block text-white mb-2">Select Item</label>
                            <div class="relative">
                                <input type="text" id="itemSearch" placeholder="Search items..." 
                                       class="w-full bg-[#1a1a1a] border border-[#333] text-white p-2 rounded mb-2">
                                <div id="itemGrid" class="bg-[#1a1a1a] border border-[#333] rounded h-[300px] overflow-y-auto p-2 grid grid-cols-3 gap-2"></div>
