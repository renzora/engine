            <div id="voucherModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50">
                <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-[#2a2a2a] border border-[#333] rounded p-4 w-96">
                    <h3 class="text-white text-lg mb-4">Generate Voucher</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-white mb-2">Coins Amount</label>
                            <input type="number" id="voucherCoins" class="w-full bg-[#1a1a1a] border border-[#333] text-white p-2 rounded">
                        </div>
                        <div>
                            <label class="block text-white mb-2">Expiration Date (optional)</label>
                            <input type="datetime-local" id="voucherExpiration" class="w-full bg-[#1a1a1a] border border-[#333] text-white p-2 rounded">
                        </div>
                        <div class="flex justify-end gap-2">
                            <button id="closeVoucherModal" class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">Cancel</button>
                            <button id="saveVoucherBtn" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Generate</button>
                        </div>
                    </div>
