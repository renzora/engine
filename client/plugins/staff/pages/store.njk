            </div>
        </div>
    `;

    this.setupTabEventListeners();
    this.loadCategories();
    this.populateCategoryFilter();
},

    setupEventListeners() {
        document.getElementById('addCategoryBtn')?.addEventListener('click', () => {
            document.getElementById('categoryModal').classList.remove('hidden');
        });

        document.getElementById('closeCategoryModal')?.addEventListener('click', () => {
            document.getElementById('categoryModal').classList.add('hidden');
        });

        document.getElementById('saveCategoryBtn')?.addEventListener('click', () => {
            this.saveCategory();
        });

        document.getElementById('addItemBtn')?.addEventListener('click', () => {
            this.showItemModal();
        });

        document.getElementById('closeItemModal')?.addEventListener('click', () => {
            document.getElementById('itemModal').classList.add('hidden');
        });

        document.getElementById('saveItemBtn')?.addEventListener('click', () => {
            this.saveItem();
        });

        document.getElementById('categoryFilter')?.addEventListener('change', () => {
            this.filterItems();
        });

        document.getElementById('itemSearchFilter')?.addEventListener('input', () => {
            this.filterItems();
        });

        document.getElementById('itemSearch')?.addEventListener('input', (e) => {
            this.filterItemGrid(e.target.value);
        });

        this.setupVoucherEventListeners();
    },

    setupTabEventListeners() {
        const categoriesBtn = document.getElementById('categoriesTabBtn');
        const itemsBtn = document.getElementById('itemsTabBtn');
        const vouchersBtn = document.getElementById('vouchersTabBtn');

        categoriesBtn.onclick = () => this.switchToTab('categories');
        itemsBtn.onclick = () => this.switchToTab('items');
        vouchersBtn.onclick = () => {
            this.switchToTab('vouchers');
            this.loadVouchers();
        };
    },

    setupVoucherEventListeners() {
        document.getElementById('addVoucherBtn').onclick = () => {
            document.getElementById('voucherModal').classList.remove('hidden');
        };

        document.getElementById('closeVoucherModal').onclick = () => {
            document.getElementById('voucherModal').classList.add('hidden');
        };

        document.getElementById('saveVoucherBtn').onclick = () => {
            this.saveVoucher();
        };
    },

    switchToTab(tab) {
        const tabs = ['categories', 'items', 'vouchers'];
        tabs.forEach(t => {
            document.getElementById(`${t}TabBtn`).classList.toggle('bg-blue-600', t === tab);
            document.getElementById(`${t}TabBtn`).classList.toggle('bg-[#2a2a2a]', t !== tab);
            document.getElementById(`${t}View`).classList.toggle('hidden', t !== tab);
        });
    },

    async loadCategories() {
        try {
            const response = await fetch('/api/staff/store/categories');
            const categories = await response.json();
            
            const categoriesList = document.getElementById('categoriesList');
            categoriesList.innerHTML = '';
            
            categories.forEach(category => {
                const div = document.createElement('div');
                div.className = 'bg-[#1a1a1a] rounded p-4';
                div.innerHTML = `
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-white font-medium mb-2">${category.name}</h3>
                            <p class="text-gray-400 text-sm">${category.description}</p>
                        </div>
                        <div class="flex gap-2">
                            <button class="text-blue-400 hover:text-blue-300" onclick="store_page.editCategory('${category._id}')">Edit</button>
                            <button class="text-red-400 hover:text-red-300" onclick="store_page.deleteCategory('${category._id}')">Delete</button>
                        </div>
                    </div>
                    <div class="mt-4 flex items-center">
                        <span class="text-sm ${category.active ? 'text-green-400' : 'text-red-400'}">
                            ${category.active ? 'Active' : 'Inactive'}
                        </span>
                    </div>
                `;
                categoriesList.appendChild(div);
            });
        } catch (error) {
            console.error('Error loading categories:', error);
        }
    },

async loadItems() {
        try {
            const response = await fetch('/api/staff/store/items');
            const items = await response.json();
            
            const itemsList = document.getElementById('itemsList');
            itemsList.innerHTML = '';
            
            items.forEach(item => {
                const div = document.createElement('div');
                div.className = `
                    relative 
                    group 
                    bg-white/5 
                    backdrop-blur-sm 
                    rounded-xl 
                    overflow-hidden 
                    transition-all 
                    duration-300 
                    hover:bg-white/10 
                    hover:scale-[1.02] 
                    border border-white/10
                `;
                
                const coinBadge = document.createElement('div');
                coinBadge.className = `
                    absolute 
                    top-2
                    right-2
                    py-1
                    px-1
                    rounded-lg
                    bg-amber-400/90 
                    backdrop-blur-sm
                    flex 
                    items-center 
                    gap-1
                    z-10
                `;
                coinBadge.innerHTML = `
                    <svg class="w-4 h-4 text-amber-900" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M10 2a8 8 0 100 16 8 8 0 000-16zM4 10a6 6 0 1112 0 6 6 0 01-12 0z"/>
                        <path fill-rule="evenodd" d="M10 4a6 6 0 100 12 6 6 0 000-12z"/>
                    </svg>
                    <span class="font-medium text-sm text-amber-900">${item.price}</span>
                `;
                
                const canvas = document.createElement('canvas');
                const objectData = this.itemData[item.objectDataId][0];
                
                this.renderItemPreview(canvas, objectData);
                
                const previewContainer = document.createElement('div');
                previewContainer.className = `
                    flex 
                    items-center 
                    justify-center 
                    h-[160px] 
                    bg-gradient-to-b 
                    from-black/20 
                    to-black/5
                `;
                previewContainer.appendChild(canvas);

                const contentContainer = document.createElement('div');
                contentContainer.className = 'p-2 space-y-3';
                
                const header = document.createElement('div');
                header.className = 'flex justify-between items-start';
const rarityColors = {
    Common: 'text-gray-400',
    Uncommon: 'text-green-400',
    Rare: 'text-blue-400',
    Epic: 'text-purple-400',
    Legendary: 'text-yellow-400'
};

header.innerHTML = `
    <h3 class="text-white font-medium text-lg leading-tight">${item.name}</h3>
    <span class="${rarityColors[item.rarity] || 'text-gray-400'}">${item.rarity || 'Common'}</span>
`;

                const actions = document.createElement('div');
                actions.className = `
                    flex 
                    gap-2 
                    pt-3 
                    mt-3 
                    border-t 
                    border-white/10
                `;
                actions.innerHTML = `
                    <button 
                        onclick="store_page.editItem('${item._id}')"
                        class="p-2 text-white/70 hover:text-white bg-white/5 hover:bg-white/10 rounded-lg transition-colors"
                        title="Edit"
                    >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                    </button>
                    <button 
                        onclick="store_page.deleteItem('${item._id}')"
                        class="p-2 text-red-400 hover:text-red-300 bg-red-400/10 hover:bg-red-400/20 rounded-lg transition-colors"
                        title="Delete"
                    >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                    </button>
                `;

                contentContainer.appendChild(header);
                contentContainer.appendChild(actions);
                
                div.appendChild(coinBadge);
                div.appendChild(previewContainer);
                div.appendChild(contentContainer);
                itemsList.appendChild(div);
            });
        } catch (error) {
            console.error('Error loading items:', error);
        }
    },

    async loadVouchers() {
        try {
            const response = await fetch('/api/staff/store/vouchers');
            const vouchers = await response.json();
            
            const vouchersList = document.getElementById('vouchersList');
            vouchersList.innerHTML = '';
            
            vouchers.forEach(voucher => {
                const tr = document.createElement('tr');
                tr.className = 'border-b border-[#333]';
                tr.innerHTML = `
                    <td class="p-3">${voucher.code}</td>
                    <td class="p-3">${voucher.coins}</td>
                    <td class="p-3">${voucher.active ? (voucher.usedBy ? 'Used' : 'Active') : 'Inactive'}</td>
                    <td class="p-3">${voucher.usedBy ? voucher.usedBy.username : '-'}</td>
                    <td class="p-3">${new Date(voucher.created * 1000).toLocaleDateString()}</td>
                    <td class="p-3">${voucher.expiresAt ? new Date(voucher.expiresAt * 1000).toLocaleDateString() : '-'}</td>
                    <td class="p-3">
                        <button class="text-red-400 hover:text-red-300" onclick="store_page.deleteVoucher('${voucher._id}')">Delete</button>
                    </td>
                `;
                vouchersList.appendChild(tr);
            });
        } catch (error) {
            console.error('Error loading vouchers:', error);
        }
    },

    renderItemPreview(canvas, itemData) {
        const ctx = canvas.getContext('2d');
        const maxPreviewSize = 120;
        const scale = Math.min(
            maxPreviewSize / ((itemData.a + 1) * 16),
            maxPreviewSize / ((itemData.b + 1) * 16)
        );
        
        canvas.width = (itemData.a + 1) * 16 * scale;
        canvas.height = (itemData.b + 1) * 16 * scale;
        
        ctx.imageSmoothingEnabled = false;
        ctx.scale(scale, scale);
        
        this.drawItem(ctx, itemData);
    },

    drawItem(ctx, itemData) {
        const tileSize = 16;
        const tilesPerRow = 150;
        
        let framesToRender = [];
        if (itemData.d && Array.isArray(itemData.i[0])) {
            framesToRender = itemData.i[0];
        } else if (Array.isArray(itemData.i[0])) {
            framesToRender = itemData.i.flat();
        } else {
            framesToRender = itemData.i.map(frame => {
                if (typeof frame === 'string' && frame.includes('-')) {
                    return game.parseRange(frame);
                }
                return [frame];
            }).flat();
        }

        const img = assets.use(itemData.t);
        if (!img) return;

        framesToRender.forEach((frame, index) => {
            const srcX = (frame % tilesPerRow) * tileSize;
            const srcY = Math.floor(frame / tilesPerRow) * tileSize;
            const destX = (index % (itemData.a + 1)) * tileSize;
            const destY = Math.floor(index / (itemData.a + 1)) * tileSize;
            ctx.drawImage(img, srcX, srcY, tileSize, tileSize, destX, destY, tileSize, tileSize);
        });
    },

    async populateCategoryFilter() {
        try {
            const response = await fetch('/api/staff/store/categories');
            const categories = await response.json();
            
            const categoryFilter = document.getElementById('categoryFilter');
            const itemCategorySelect = document.getElementById('itemCategory');
            
            [categoryFilter, itemCategorySelect].forEach(select => {
                if (select) {
                    select.innerHTML = '<option value="">All Categories</option>';
                    categories.forEach(category => {
                        const option = document.createElement('option');
                        option.value = category._id;
                        option.textContent = category.name;
                        select.appendChild(option);
                    });
                }
            });
        } catch (error) {
            console.error('Error loading categories for filter:', error);
        }
    },

    async filterItems() {
        const categoryId = document.getElementById('categoryFilter').value;
        const searchTerm = document.getElementById('itemSearchFilter').value.toLowerCase();
        
        try {
            const response = await fetch('/api/staff/store/items');
            const items = await response.json();
            
            const filteredItems = items.filter(item => {
                const matchesCategory = !categoryId || item.categoryId === categoryId;
                const matchesSearch = item.name.toLowerCase().includes(searchTerm);
                return matchesCategory && matchesSearch;
            });
            
            const itemsList = document.getElementById('itemsList');
            itemsList.innerHTML = '';
            
            filteredItems.forEach(item => {
                // Reuse existing item rendering code
                const div = document.createElement('div');
                div.className = 'bg-[#1a1a1a] rounded p-4 flex flex-col h-[220px]';
                
                const canvas = document.createElement('canvas');
                const objectData = this.itemData[item.objectDataId][0];
                
                this.renderItemPreview(canvas, objectData);
                
                const previewContainer = document.createElement('div');
                previewContainer.className = 'flex items-center justify-center h-[120px]';
                previewContainer.appendChild(canvas);

                const infoContainer = document.createElement('div');
                infoContainer.className = 'mt-4 flex flex-col gap-2';
                infoContainer.innerHTML = `
                    <div class="text-white font-medium truncate" title="${item.name}">${item.name}</div>
                    <div class="text-gray-400">${item.price} coins</div>
                    <div class="flex justify-end gap-2 mt-auto">
                        <button class="text-blue-400 hover:text-blue-300" onclick="store_page.editItem('${item._id}')">Edit</button>
                        <button class="text-red-400 hover:text-red-300" onclick="store_page.deleteItem('${item._id}')">Delete</button>
                    </div>
                `;

                div.appendChild(previewContainer);
                div.appendChild(infoContainer);
                itemsList.appendChild(div);
            });
        } catch (error) {
            console.error('Error filtering items:', error);
        }
    },

    filterItemGrid(searchTerm) {
        const grid = document.getElementById('itemGrid');
        grid.innerHTML = '';
        
        searchTerm = searchTerm.toLowerCase();
        
        Object.entries(this.itemData).forEach(([id, items]) => {
            const itemData = items[0];
            if (itemData.n.toLowerCase().includes(searchTerm)) {
                const canvas = document.createElement('canvas');
                this.renderItemPreview(canvas, itemData);
                
                const wrapper = document.createElement('div');
                wrapper.className = `
                    bg-[#2a2a2a] p-2 rounded cursor-pointer hover:bg-[#3a3a3a] 
                    flex flex-col items-center transition-all duration-200
                    ${this.selectedObjectIds.has(id) ? 'ring-2 ring-blue-500' : ''}
                `;
                
                const canvasWrapper = document.createElement('div');
                canvasWrapper.className = 'flex items-center justify-center h-[80px]';
                canvasWrapper.appendChild(canvas);
                
                const nameLabel = document.createElement('div');
                nameLabel.className = 'text-white text-xs text-center mt-2 truncate w-full';
                nameLabel.title = itemData.n;
                nameLabel.textContent = itemData.n;
                
                wrapper.appendChild(canvasWrapper);
                wrapper.appendChild(nameLabel);
                
                wrapper.onclick = (e) => this.selectItem(id, e.ctrlKey || e.metaKey);
                grid.appendChild(wrapper);
            }
        });
    },

    selectItem(objectId, multiSelect = false) {
        if (!this.selectedObjectIds) {
            this.selectedObjectIds = new Set();
        }

        if (multiSelect) {
            if (this.selectedObjectIds.has(objectId)) {
                this.selectedObjectIds.delete(objectId);
            } else {
                this.selectedObjectIds.add(objectId);
            }
        } else {
            this.selectedObjectIds.clear();
            this.selectedObjectIds.add(objectId);
        }

        this.filterItemGrid(document.getElementById('itemSearch').value);
    },

    async saveCategory() {
        const category = {
            name: document.getElementById('categoryName').value,
            description: document.getElementById('categoryDescription').value,
            active: document.getElementById('categoryActive').checked
        };

        if (!category.name) {
            alert('Please enter a category name');
            return;
        }

        try {
            const response = await fetch('/api/staff/store/categories', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(category)
            });

            if (response.ok) {
                document.getElementById('categoryModal').classList.add('hidden');
                this.loadCategories();
